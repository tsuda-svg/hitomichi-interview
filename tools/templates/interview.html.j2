<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ title }} — {{ interviewee.name }} ｜ 人道</title>
<meta name="description" content="{{ description }}" />

<!-- ===== Open Graph ===== -->
<meta property="og:type" content="article" />
<meta property="og:site_name" content="人道" />
<meta property="og:title" content="{{ title }} — {{ interviewee.name }}" />
<meta property="og:description" content="{{ description }}" />
<meta property="og:url" content="https://hitomichi-interview.vercel.app/{{ slug }}.html" />
<meta property="og:image" content="https://hitomichi-interview.vercel.app/assets/og-image.jpg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="人道 HITOMICHI — {{ title }}" />
<meta property="og:locale" content="ja_JP" />

<!-- ===== Twitter Card ===== -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ title }} — {{ interviewee.name }}" />
<meta name="twitter:description" content="{{ description }}" />
<meta name="twitter:image" content="https://hitomichi-interview.vercel.app/assets/og-image.jpg" />
<meta name="twitter:image:alt" content="人道 HITOMICHI — {{ interviewee.name }}インタビュー" />

<link rel="icon" type="image/png" sizes="32x32" href="assets/favicon-32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="assets/favicon-16.png" />
<link rel="icon" type="image/png" sizes="192x192" href="assets/favicon-192.png" />
<link rel="apple-touch-icon" sizes="180x180" href="assets/apple-touch-icon.png" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@400;500;600&family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          ink: '#0F1417',
          'ink-soft': '#4A5159',
          'ink-mute': '#8A8F95',
          paper: '#FFFFFF',
          'paper-soft': '#F6F4EF',
          'paper-tint': '#FAF8F3',
          accent: '#1B3A5C',
          'accent-deep': '#122A45',
          'accent-soft': '#E8EDF4',
          line: '#E5E2DA',
        },
        fontFamily: {
          serif: ['"Noto Serif JP"','serif'],
          sans: ['"Noto Sans JP"','sans-serif'],
        },
        maxWidth: {
          container: '1240px',
          article: '760px',
        }
      }
    }
  }
</script>

<link rel="stylesheet" href="assets/style.css" />
</head>
<body class="bg-paper text-ink">

<!-- ============ HEADER ============ -->
<header class="site-header" data-header-style="light">
  <div class="max-w-container mx-auto px-6 lg:px-10 h-[78px] flex items-center justify-between">
    <a href="index.html" class="header-logo flex items-center">
      <img class="logo-dark h-10 lg:h-12 w-auto" src="assets/logo-horizontal.png" srcset="assets/logo-horizontal.png 1x, assets/logo-horizontal@2x.png 2x" alt="HITOMICHI 人道" />
      <img class="logo-light h-10 lg:h-12 w-auto" src="assets/logo-horizontal-white.png" srcset="assets/logo-horizontal-white.png 1x, assets/logo-horizontal-white@2x.png 2x" alt="HITOMICHI 人道" />
    </a>
    <nav class="hidden md:flex items-center gap-9">
      <a href="index.html#latest" class="nav-link">新着記事</a>
      <a href="index.html#special" class="nav-link">特別対談</a>
      <a href="index.html#interview" class="nav-link">インタビュー</a>
      <a href="index.html#column" class="nav-link">コラム</a>
      <a href="index.html#tags" class="nav-link">タグ一覧</a>
    </nav>
    <div class="flex items-center gap-5">
      <button class="header-icon" aria-label="検索">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- ============ ARTICLE HERO ============ -->
<section class="relative h-[88vh] min-h-[600px] w-full overflow-hidden">
  <img src="{{ images.hero }}"
       alt="{{ interviewee.name }}" class="absolute inset-0 w-full h-full object-cover" style="filter: grayscale(0.2) contrast(1.05) brightness(0.8); object-position: center 30%;" />
  <div class="absolute inset-0 hero-overlay"></div>

  <div class="relative z-10 h-full max-w-container mx-auto px-6 lg:px-10 text-white flex flex-col justify-end pb-20 lg:pb-24">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5 text-[11px] tracking-[0.4em] uppercase opacity-90">
        <span class="inline-block w-10 h-px bg-white/80"></span>
        Interview — {{ volume }}
      </div>
      <div class="flex items-center gap-2 flex-wrap mb-6">
        {% for theme in themes %}
        <span class="meta-tag theme" style="background: rgba(232,237,244,0.15); border-color: rgba(232,237,244,0.2); color:#fff;">{{ theme }}</span>
        {% endfor %}
        <span class="meta-tag" style="background: transparent; border-color: rgba(255,255,255,0.3); color:#fff;">{{ industry }}</span>
        <span class="meta-tag" style="background: transparent; border-color: rgba(255,255,255,0.3); color:#fff;">{{ size }}</span>
      </div>
      <h1 class="font-display text-[36px] sm:text-[48px] lg:text-[60px] leading-[1.3] font-medium mb-6">
        {{ title|replace('、', '、<br/>')|safe }}
      </h1>
      <p class="font-serif-jp text-[15px] sm:text-[16px] leading-[2] opacity-90 max-w-2xl">
        {{ subtitle|default('') }}
      </p>
      <div class="mt-10 flex items-center flex-wrap gap-x-5 gap-y-2 text-[12px] tracking-[0.15em] opacity-85">
        <span>{{ date }}</span>
        <span class="inline-block w-6 h-px bg-white/40 hidden sm:inline-block"></span>
        <span>READ {{ read_minutes|default(8) }} MIN</span>
        <span class="inline-block w-6 h-px bg-white/40 hidden sm:inline-block"></span>
        <span>Interviewer ｜ {{ interviewer|default('編集部') }}</span>
      </div>
    </div>
  </div>
</section>

<!-- ============ BREADCRUMB ============ -->
<div class="border-b border-line">
  <div class="max-w-container mx-auto px-6 lg:px-10 py-4 text-[11px] tracking-[0.1em] text-ink-mute">
    <a href="index.html" class="hover:text-accent">HOME</a> ／
    <a href="index.html#interview" class="hover:text-accent">Interview</a> ／
    <span class="text-ink">{{ title }}</span>
  </div>
</div>

<!-- ============ ARTICLE BODY ============ -->
<article class="py-16 lg:py-24">
  <div class="max-w-article mx-auto px-6">

    <!-- Profile card -->
    <aside class="mb-16 border border-line bg-paper-tint p-7 lg:p-9 flex flex-col sm:flex-row gap-6 items-start">
      <img src="{{ images.profile }}"
           class="w-20 h-20 rounded-full object-cover" style="object-position: center 30%;" alt="" />
      <div class="flex-1">
        <div class="font-en-sans text-[10px] tracking-[0.3em] text-accent mb-2">PROFILE</div>
        <h2 class="font-serif-jp text-[22px] mb-1">{{ interviewee.name }}<span class="text-ink-mute text-[12px] ml-3 tracking-[0.1em]">{{ interviewee.name_en }}</span></h2>
        <p class="text-[13px] text-ink-soft leading-[1.9] mb-3">
          {{ company.name }} {{ interviewee.role }}
        </p>
        <p class="text-[13px] text-ink-soft leading-[1.95]">
          {{ interviewee.bio }}
        </p>
      </div>
    </aside>

    <!-- Body content -->
    <div class="article-body">
      <p class="lead">
        {{ lead }}
      </p>

      {% for qa in qas %}
      <h2>{{ qa.question }}</h2>
      {% for para in qa.paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
      {% endfor %}

      {% if quote %}
      <blockquote class="pull-quote my-12">
        {{ quote }}
      </blockquote>
      {% endif %}
    </div>

    <!-- Editor's note -->
    {% if editor_note %}
    <div class="editor-note mt-20">
      <div class="font-en-sans text-[10px] tracking-[0.3em] text-accent mb-3">EDITOR'S NOTE</div>
      <p class="font-serif-jp text-[15px] leading-[2] text-ink">
        {{ editor_note }}
      </p>
    </div>
    {% endif %}

    <!-- Share -->
    <div class="mt-16 flex items-center justify-between flex-wrap gap-4 border-t border-line pt-8">
      <div class="font-en-sans text-[10px] tracking-[0.3em] text-ink-mute">SHARE THIS INTERVIEW</div>
      <div class="flex gap-4">
        <a href="https://twitter.com/intent/tweet?url=https://hitomichi-interview.vercel.app/{{ slug }}.html&text={{ title|urlencode }}" target="_blank" class="w-10 h-10 border border-line flex items-center justify-center hover:border-accent hover:text-accent transition" aria-label="X">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.facebook.com/sharer/sharer.php?u=https://hitomichi-interview.vercel.app/{{ slug }}.html" target="_blank" class="w-10 h-10 border border-line flex items-center justify-center hover:border-accent hover:text-accent transition" aria-label="Facebook">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.99 22 12"/></svg>
        </a>
        <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://hitomichi-interview.vercel.app/{{ slug }}.html" target="_blank" class="w-10 h-10 border border-line flex items-center justify-center hover:border-accent hover:text-accent transition" aria-label="LinkedIn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zM8.339 18.337v-8.59H5.667v8.59zM7.003 8.575a1.55 1.55 0 1 0 0-3.1 1.55 1.55 0 0 0 0 3.1m11.335 9.762v-4.717c0-2.598-1.404-3.806-3.275-3.806-1.51 0-2.187.83-2.564 1.412v-1.213h-2.844c.037.804 0 8.59 0 8.59h2.844v-4.797c0-.256.018-.512.094-.694.205-.51.674-1.04 1.461-1.04 1.03 0 1.442.785 1.442 1.937v4.594z"/></svg>
        </a>
      </div>
    </div>

  </div>
</article>

<!-- ============ COMPANY ============ -->
<section class="bg-paper-soft border-t border-line py-20 lg:py-24">
  <div class="max-w-3xl mx-auto px-6 lg:px-10">
    <div class="text-center mb-12">
      <div class="font-en text-[14px] tracking-[0.3em] uppercase text-accent mb-3">— Company</div>
      <h2 class="font-serif-jp text-[26px] lg:text-[30px] leading-[1.4]">取材先企業</h2>
    </div>

    <div class="bg-white p-8 lg:p-12 border border-line">
      <div class="flex items-start gap-6 mb-10 pb-8 border-b border-line">
        <div class="w-20 h-20 lg:w-24 lg:h-24 bg-accent text-white flex items-center justify-center font-serif-jp text-[30px] shrink-0">{{ company.logo_letter|default(company.name[0]) }}</div>
        <div class="flex-1 pt-2">
          <h3 class="font-serif-jp text-[20px] lg:text-[24px] leading-[1.4] mb-2">{{ company.name }}</h3>
          <p class="text-ink-mute text-[13px] tracking-[0.04em]">{{ company.tagline }}</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10 pb-10 border-b border-line">
        <div>
          <div class="font-en-sans text-[10px] tracking-[0.2em] uppercase text-ink-mute mb-2">Founded</div>
          <div class="font-serif-jp text-[15px]">{{ company.founded }}</div>
        </div>
        <div>
          <div class="font-en-sans text-[10px] tracking-[0.2em] uppercase text-ink-mute mb-2">Employees</div>
          <div class="font-serif-jp text-[15px]">{{ company.employees }}</div>
        </div>
        <div>
          <div class="font-en-sans text-[10px] tracking-[0.2em] uppercase text-ink-mute mb-2">Industry</div>
          <div class="font-serif-jp text-[15px]">{{ company.industry }}</div>
        </div>
        <div>
          <div class="font-en-sans text-[10px] tracking-[0.2em] uppercase text-ink-mute mb-2">Headquarters</div>
          <div class="font-serif-jp text-[15px]">{{ company.hq }}</div>
        </div>
      </div>

      <div>
        <p class="text-ink-soft text-[14px] leading-[2]">{{ company.description }}</p>
        {% if company.website %}
        <a href="{{ company.website }}" target="_blank" rel="noopener" class="inline-flex items-center gap-3 mt-6 font-en-sans text-[11px] tracking-[0.24em] uppercase text-accent hover:text-ink transition-colors">
          公式サイトを見る
          <span>→</span>
        </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<!-- ============ CAREER ============ -->
<section class="py-20 lg:py-24 bg-accent text-white">
  <div class="max-w-3xl mx-auto px-6 lg:px-10">
    <div class="text-center mb-14">
      <div class="font-en text-[14px] tracking-[0.3em] uppercase opacity-80 mb-3">— Career</div>
      <h2 class="font-serif-jp text-[26px] lg:text-[32px] leading-[1.4]">この組織と、共に働く。</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-10 lg:gap-14 mb-14 max-w-2xl mx-auto">
      <div>
        <div class="font-en-sans text-[11px] tracking-[0.24em] uppercase text-white/70 mb-4">Open Positions</div>
        <ul class="space-y-2 text-[14px] leading-[1.95] font-serif-jp">
          {% for position in career.positions %}
          <li>— {{ position }}</li>
          {% endfor %}
        </ul>
      </div>

      <div>
        <div class="font-en-sans text-[11px] tracking-[0.24em] uppercase text-white/70 mb-4">求める人物像</div>
        <p class="text-[14px] leading-[2] opacity-90 font-serif-jp">{{ career.persona }}</p>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center max-w-2xl mx-auto">
      {% if career.recruit_url %}
      <a href="{{ career.recruit_url }}" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-3 bg-white text-accent px-8 py-4 text-[14px] tracking-[0.16em] hover:bg-paper-soft transition-colors font-serif-jp flex-1">
        採用情報を見る
        <span>→</span>
      </a>
      {% endif %}
      {% if career.casual_url %}
      <a href="{{ career.casual_url }}" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-3 border border-white/50 text-white px-8 py-4 text-[14px] tracking-[0.16em] hover:bg-white hover:text-accent transition-colors font-serif-jp flex-1">
        カジュアル面談を申し込む
        <span>→</span>
      </a>
      {% endif %}
    </div>

    <p class="text-center text-[11px] text-white/60 mt-8 tracking-[0.08em]">
      ※ 採用に関するお問い合わせは、取材先企業へ直接お願いいたします。
    </p>
  </div>
</section>

<!-- ============ RELATED ============ -->
<section class="py-20 lg:py-24 bg-paper-soft">
  <div class="max-w-container mx-auto px-6 lg:px-10">
    <div class="mb-12">
      <div class="section-eyebrow mb-4">Related</div>
      <h2 class="section-title text-[26px] lg:text-[32px]">この記事を読んだ方には、こちらも。</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
      {% for r in related %}
      <a href="{{ r.url }}" class="card block{% if r.coming_soon %} coming-soon{% endif %}">
        <div class="thumb aspect-[5/4] mb-6">
          <img src="{{ r.image }}" style="filter: grayscale(0.3);" alt="" />
        </div>
        <div class="flex items-center gap-2 flex-wrap mb-3">
          {% for theme in r.themes %}
          <span class="meta-tag theme">{{ theme }}</span>
          {% endfor %}
          <span class="meta-tag">{{ r.industry }}</span>
        </div>
        <h3 class="card-title text-[18px] mb-2 leading-[1.55]">{{ r.title }}</h3>
        <p class="text-ink-mute text-[12px] tracking-[0.08em]">{{ r.byline }}</p>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ============ NEWSLETTER ============ -->
<section class="py-20 lg:py-24 bg-accent text-white">
  <div class="max-w-container mx-auto px-6 lg:px-10 grid lg:grid-cols-2 gap-10 items-center">
    <div>
      <div class="font-en-sans text-[11px] tracking-[0.3em] opacity-80 mb-4">— Letter from HITOMICHI</div>
      <h2 class="font-serif-jp text-[28px] lg:text-[34px] leading-[1.4]">毎週金曜、<br/>HRの一篇を、お手元へ。</h2>
      <p class="text-[14px] leading-[2] mt-6 opacity-85 max-w-md">編集部が選ぶ今週のインタビューと、現場で実践できる小さな洞察を、メールで。</p>
    </div>
    <form class="flex items-stretch gap-3 bg-white p-2" onsubmit="event.preventDefault(); alert('ニュースレター配信は現在準備中です。公開準備が整いましたら、サイト上でお知らせいたします。');">
      <input type="email" placeholder="準備中" class="flex-1 px-4 py-3 text-ink text-[14px] focus:outline-none placeholder:text-ink-mute" disabled />
      <button type="submit" class="bg-accent-deep text-white px-7 text-[12px] tracking-[0.2em] uppercase hover:bg-ink transition-colors opacity-60 cursor-not-allowed" disabled>Coming Soon</button>
    </form>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<footer class="footer pt-16 pb-10">
  <div class="max-w-container mx-auto px-6 lg:px-10">
    <div class="grid md:grid-cols-4 gap-10 mb-14">
      <div class="md:col-span-1">
        <div class="mb-5">
          <img src="assets/logo-horizontal-white.png" srcset="assets/logo-horizontal-white.png 1x, assets/logo-horizontal-white@2x.png 2x" alt="HITOMICHI 人道" class="h-10 w-auto" />
        </div>
        <p class="text-[12px] leading-[2] text-white/70">人を、企業の資本に。<br/>HR実践者のためのインタビューメディア。</p>
      </div>
      <div>
        <div class="font-en-sans text-[10px] text-white/60 mb-4">Read</div>
        <ul class="space-y-3 text-[13px]">
          <li><a href="index.html#latest">新着記事</a></li>
          <li><a href="index.html#special">特別対談</a></li>
          <li><a href="index.html#interview">インタビュー</a></li>
          <li><a href="index.html#column">コラム</a></li>
          <li><a href="index.html#tags">タグ一覧</a></li>
        </ul>
      </div>
      <div>
        <div class="font-en-sans text-[10px] text-white/60 mb-4">Service</div>
        <ul class="space-y-3 text-[13px]">
          <li><a href="#">HITOMICHI Conference</a></li>
          <li><a href="#">HITOMICHI Awards</a></li>
          <li><a href="#">HR Practitioners' Salon</a></li>
          <li><a href="#">Newsletter</a></li>
        </ul>
      </div>
      <div>
        <div class="font-en-sans text-[10px] text-white/60 mb-4">About</div>
        <ul class="space-y-3 text-[13px]">
          <li><a href="https://kaimaku.jp/" target="_blank" rel="noopener">運営会社</a></li>
          <li><a href="#">編集方針</a></li>
          <li><a href="#">広告掲載</a></li>
          <li><a href="#">取材依頼</a></li>
          <li><a href="#">プライバシーポリシー</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 pt-6 flex flex-wrap justify-between items-center gap-4 text-[11px] text-white/50">
      <div>© 2026 HITOMICHI Editorial. All rights reserved.</div>
      <div class="flex gap-5">
        <a href="#">X</a>
        <a href="#">Facebook</a>
        <a href="#">LinkedIn</a>
        <a href="#">note</a>
      </div>
    </div>
  </div>
</footer>

<script src="assets/script.js"></script>
</body>
</html>
